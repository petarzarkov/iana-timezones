{
  "name": "iana-db-timezones",
  "description": "Auto-generated IANA timezone data with rich metadata, no dependencies, full TypeScript support, and Node/browser compatibility.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "author": {
    "name": "Petar Zarkov",
    "email": "pzarko1@gmail.com",
    "url": "https://github.com/petarzarkov"
  },
  "license": "MIT",
  "version": "0.2.8",
  "engines": {
    "node": ">= 22.15.0",
    "pnpm": ">= 10.9.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petarzarkov/iana-timezones.git"
  },
  "homepage": "https://github.com/petarzarkov/iana-timezones",
  "scripts": {
    "prepare": "node -e \"process.env.CI || process.env.DOCKER || process.exit(1)\" || husky",
    "generate": "tsx --env-file=.env src/generateTimezones.ts",
    "typecheck": "tsc --noEmit",
    "prebuild": "rm -rf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:dev": "vitest dev",
    "lint": "eslint --cache src/**",
    "pretty": "prettier --cache --ignore-unknown --write .",
    "versioning": "tsx --env-file=.env src/version.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/node": "25.5.2",
    "@types/tar-stream": "3.1.4",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitest/coverage-v8": "4.1.3",
    "csv-parse": "6.2.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "rollup": "4.60.1",
    "tar-stream": "3.1.8",
    "tslib": "2.8.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.3"
  },
  "packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f",
  "keywords": [
    "iana",
    "time",
    "tz",
    "timezone",
    "timezones",
    "tzdb",
    "list",
    "db",
    "datetime",
    "date",
    "utc",
    "gmt",
    "offset",
    "timezone offset",
    "no deps",
    "static data",
    "typescript",
    "json"
  ]
}
