{
  "name": "iana-db-timezones",
  "version": "0.2.8",
  "description": "Auto-generated IANA timezone data with rich metadata, no dependencies, full TypeScript support, and Node/browser compatibility.",
  "keywords": [
    "date",
    "datetime",
    "db",
    "gmt",
    "iana",
    "json",
    "list",
    "no deps",
    "offset",
    "static data",
    "time",
    "timezone",
    "timezone offset",
    "timezones",
    "typescript",
    "tz",
    "tzdb",
    "utc"
  ],
  "homepage": "https://github.com/petarzarkov/iana-timezones",
  "license": "MIT",
  "author": {
    "name": "Petar Zarkov",
    "email": "pzarko1@gmail.com",
    "url": "https://github.com/petarzarkov"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petarzarkov/iana-timezones.git"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "bun -e \"process.env.CI || process.env.DOCKER || process.exit(1)\" || husky",
    "generate": "bun --env-file=.env src/generateTimezones.ts",
    "typecheck": "tsc --noEmit",
    "prebuild": "rm -rf dist",
    "build": "rollup -c",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:dev": "vitest dev",
    "lint": "oxlint src/",
    "format": "oxfmt --write .",
    "versioning": "bun --env-file=.env src/version.ts"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@types/tar-stream": "3.1.4",
    "@vitest/coverage-v8": "4.1.4",
    "csv-parse": "6.2.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0",
    "rollup": "4.60.1",
    "tar-stream": "3.1.8",
    "tslib": "2.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  },
  "engines": {
    "bun": ">= 1.3.0",
    "node": ">= 22.15.0"
  },
  "packageManager": "bun@1.3.12"
}
